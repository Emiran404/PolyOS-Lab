{
  "name": "dashboard",
  "private": true,
  "version": "1.4.9",
  "description": "PolyOS Lab Teacher Dashboard",
  "author": "Emirhan Gok <emiran404@github.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Emiran404/PolyOS-Lab.git"
  },
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:start": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5170 && npm run electron:start\"",
    "electron:build": "npm run build && electron-builder --publish never"
  },
  "build": {
    "appId": "com.polyos.lab.dashboard",
    "productName": "PolyOS Lab Öğretmen Paneli",
    "artifactName": "polyos-lab-ogretmen-paneli_${version}_${arch}.${ext}",
    "directories": {
      "output": "release/"
    },
    "extraResources": [
      {
        "from": "../server/polyos-server",
        "to": "polyos-server"
      }
    ],
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Education"
    }
  },
  "dependencies": {
    "@novnc/novnc": "^1.7.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
